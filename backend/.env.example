# ==============================
#  VaultX - Variables d'environnement
# ==============================

# Serveur
PORT=3001
NODE_ENV=development

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vaultx
DB_USER=vaultx_user
DB_PASSWORD=ton_mot_de_passe_db

# JWT
JWT_SECRET=change_moi_avec_une_longue_chaine_aleatoire_de_64_caracteres
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_moi_aussi_avec_une_autre_chaine_aleatoire
JWT_REFRESH_EXPIRES_IN=30d

# Chiffrement AES-256
ENCRYPTION_KEY=change_moi_64_caracteres_hex_exactement_32_bytes_en_hex_ici00
# Générer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Stripe (optionnel pour l'instant)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
